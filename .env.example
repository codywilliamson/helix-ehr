# =============================================================================
# helix-ehr — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# =============================================================================

# --- Next.js ---
# The base URL for the application (used for NextAuth and API routes)
NEXTAUTH_URL=http://localhost:3000

# A random secret used to sign/encrypt NextAuth.js JWT tokens
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Hasura ---
# The URL of the Hasura GraphQL Engine
NEXT_PUBLIC_HASURA_GRAPHQL_URL=http://localhost:8080/v1/graphql

# Admin secret for Hasura console access and metadata operations
HASURA_GRAPHQL_ADMIN_SECRET=your-hasura-admin-secret

# --- PostgreSQL ---
# Connection string for the PostgreSQL database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/helix_ehr
